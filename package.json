{
  "name": "wtr-energia-solar",
  "version": "1.0.0",
  "description": "Site institucional WTR Energia Solar",
  "scripts": {
    "dev": "live-server --port=3000",
    "build": "npm run css:build && npm run js:build",
    "css:build": "postcss styles/main.css -o dist/styles/main.css",
    "js:build": "terser scripts/main.js -o dist/scripts/main.js",
    "test": "node tests/accessibility.test.js",
    "lint": "eslint scripts/**/*.js"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "postcss": "^8.4.0",
    "postcss-cli": "^10.0.0",
    "terser": "^5.0.0",
    "eslint": "^8.0.0"
  }
}